# ============================================================
# 并行开发编排引擎 —— 环境配置示例
# ============================================================
# 用法：复制为同目录下的 .env，按所选引擎填写。
#   cp .env.example .env
# 或运行交互式向导自动生成：
#   python3 scripts/setup.py
#
# .env 只需放一种引擎的配置。引擎由 ENGINE_TYPE 决定。
# ------------------------------------------------------------

# 引擎类型：mock | github | multica
ENGINE_TYPE=mock

# ---------- mock（本地空跑，不连任何平台，用于先验证机制） ----------
MOCK_WORKSPACE_ID=demo-workspace

# ---------- github（issue 即 GitHub Issue，需要 gh CLI） ----------
# ENGINE_TYPE=github
# GITHUB_REPO=owner/repo          # 必填，格式 owner/repo
# GITHUB_TOKEN=                   # 可选，提高 API 限额（建议设）

# ---------- multica（需要 multica CLI 并已登录） ----------
# ENGINE_TYPE=multica
# MULTICA_WORKSPACE_ID=           # 必填，`multica workspace list` 查看
# MULTICA_SQUAD_ID=               # 可选，默认从 manifest 的 squad 字段取

# manifest 字段支持 ${VAR:-默认值} 展开；若 manifest 用 ${MULTICA_TEST_SQUAD:-...}
# 驱动 squad，可在此或 shell 里设置，避免把 squad id 硬写进 manifest 文件：
# MULTICA_TEST_SQUAD=

# ---------- 轮询节奏（可选，单位秒） ----------
# POLLING_INTERVAL=30
# POLLING_INTERVAL_MIN=10
# POLLING_INTERVAL_MAX=300
